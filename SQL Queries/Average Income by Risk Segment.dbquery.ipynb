   "outputs": [],
   "source": [
    "SELECT \n",
    "    risk_segment,\n",
    "    ROUND(AVG(avg_income), 2) as average_income,\n",
    "    ROUND(AVG(avg_credit_amount), 2) as average_credit\n",
    "FROM dm2_credit_risk.gold_credit_risk_metrics\n",
    "GROUP BY risk_segment\n",
    "ORDER BY average_income DESC;"
   ]
  }
