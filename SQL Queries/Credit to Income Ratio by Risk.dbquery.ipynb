   "source": [
    "SELECT \n",
    "    risk_segment,\n",
    "    ROUND(AVG(avg_credit_to_income_ratio), 2) as avg_ratio\n",
    "FROM dm2_credit_risk.gold_credit_risk_metrics\n",
    "GROUP BY risk_segment\n",
    "ORDER BY avg_ratio DESC;"
   ]
