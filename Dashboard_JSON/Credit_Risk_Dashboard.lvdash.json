{
  "datasets": [
    {
      "name": "098b162a",
      "displayName": "Default Rate by Risk Segment",
      "queryLines": [
        "SELECT \r\n",
        "    risk_segment,\r\n",
        "    default_rate_percent\r\n",
        "FROM dm2_credit_risk.gold_credit_risk_metrics\r\n",
        "GROUP BY risk_segment, default_rate_percent\r\n",
        "ORDER BY default_rate_percent DESC;"
      ],
      "catalog": "workspace",
      "schema": "dm2_credit_risk"
    },
    {
      "name": "b7dc462b",
      "displayName": "Customer Count by Risk Segment",
      "queryLines": [
        "SELECT \r\n",
        "    risk_segment,\r\n",
        "    SUM(total_customers) as customer_count\r\n",
        "FROM dm2_credit_risk.gold_credit_risk_metrics\r\n",
        "GROUP BY risk_segment\r\n",
        "ORDER BY customer_count DESC;"
      ],
      "catalog": "workspace",
      "schema": "dm2_credit_risk"
    },
    {
      "name": "79450253",
      "displayName": "Defaulted vs Non-Defaulted",
      "queryLines": [
        "SELECT \r\n",
        "    CASE \r\n",
        "        WHEN defaulted_customers > 0 THEN 'Defaulted'\r\n",
        "        ELSE 'Active'\r\n",
        "    END as status,\r\n",
        "    SUM(total_customers) as count\r\n",
        "FROM dm2_credit_risk.gold_credit_risk_metrics\r\n",
        "GROUP BY status;"
      ],
      "catalog": "workspace",
      "schema": "dm2_credit_risk"
    },
    {
      "name": "6e8b70e2",
      "displayName": "Average Income by Risk Segment",
      "queryLines": [
        "SELECT\n",
        "  risk_segment,\n",
        "  assigned_country,\n",
        "  ROUND(AVG(avg_income), 0) as average_income,\n",
        "  ROUND(AVG(country_gdp_usd), 0) as country_gdp,\n",
        "  ROUND(AVG(avg_income) / AVG(country_gdp_usd) * 100, 4) as income_as_pct_of_gdp\n",
        "FROM\n",
        "  dm2_credit_risk.gold_credit_risk_metrics\n",
        "GROUP BY\n",
        "  risk_segment,\n",
        "  assigned_country\n",
        "ORDER BY\n",
        "  average_income DESC"
      ]
    },
    {
      "name": "c8f07782",
      "displayName": "Credit to Income Ratio by Risk",
      "queryLines": [
        "SELECT\n",
        "  assigned_country,\n",
        "  risk_segment,\n",
        "  ROUND(AVG(avg_credit_to_income_ratio), 2) as avg_ratio,\n",
        "  ROUND(AVG(country_gdp_usd) / 1000000000, 2) as gdp_billions,\n",
        "  SUM(total_customers) as total_customers\n",
        "FROM\n",
        "  dm2_credit_risk.gold_credit_risk_metrics\n",
        "GROUP BY\n",
        "  assigned_country,\n",
        "  risk_segment\n",
        "ORDER BY\n",
        "  gdp_billions DESC"
      ]
    },
    {
      "name": "b6d830be",
      "displayName": "Key Metrics Summary",
      "queryLines": [
        "SELECT \r\n",
        "    SUM(total_customers) as total_customers,\r\n",
        "    SUM(defaulted_customers) as total_defaults,\r\n",
        "    ROUND(SUM(defaulted_customers) / SUM(total_customers) * 100, 2) as overall_default_rate,\r\n",
        "    ROUND(AVG(avg_income), 2) as avg_income_all\r\n",
        "FROM dm2_credit_risk.gold_credit_risk_metrics;"
      ],
      "catalog": "workspace",
      "schema": "dm2_credit_risk"
    }
  ],
